{
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/dashboard-pro", "dest": "/dashboard-pro.html" },
    { "src": "/checkout", "dest": "/checkout.html" },
    { "src": "/obrigado", "dest": "/obrigado.html" },
    { "src": "/api/(.*)", "dest": "/api/index.js" }
  ]
}
